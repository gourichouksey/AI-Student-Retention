# Copy to .env.local (development) or set in your hosting environment.
# Backend base URL for the frontend to call.
# Example (same PC): http://127.0.0.1:5000
# Example (LAN):     http://192.168.1.20:5000
VITE_API_BASE_URL=http://127.0.0.1:5000

# Google OAuth client id for login.
# Add your own OAuth Web client id from Google Cloud Console.
# VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

